{
	"name": "silo",
	"private": true,
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "bun x tsc --noEmit && vite build",
		"preview": "vite preview",
		"start": "vite preview",
		"tauri": "cargo tauri",
		"tauri:cef:install-cli": "cargo install tauri-cli --git https://github.com/tauri-apps/tauri --branch feat/cef",
		"tauri:cef:update": "cargo update --manifest-path src-tauri/Cargo.toml && cargo install tauri-cli --git https://github.com/tauri-apps/tauri --branch feat/cef --force",
		"check": "bun x @biomejs/biome check .",
		"check:fix": "bun x @biomejs/biome check --write .",
		"driver": "tsx driver/cli.ts",
		"silo-driver": "tsx driver/cli.ts",
		"e2e:preflight": "bun scripts/e2e-live-preflight.ts",
		"e2e": "bun run e2e:preflight && bunx playwright test",
		"e2e:headed": "bun run e2e:preflight && bunx playwright test --headed",
		"reset": "rm -rf \"$HOME/.silo\"",
		"reset:gcp": "bun scripts/reset_gcp.ts"
	},
	"dependencies": {
		"@codemirror/lang-cpp": "^6.0.3",
		"@codemirror/lang-css": "^6.3.1",
		"@codemirror/lang-go": "^6.0.1",
		"@codemirror/lang-html": "^6.4.11",
		"@codemirror/lang-java": "^6.0.2",
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-markdown": "^6.3.4",
		"@codemirror/lang-php": "^6.0.2",
		"@codemirror/lang-python": "^6.2.1",
		"@codemirror/lang-rust": "^6.0.1",
		"@codemirror/lang-sql": "^6.10.0",
		"@codemirror/lang-xml": "^6.1.0",
		"@codemirror/lang-yaml": "^6.1.2",
		"@codemirror/language": "^6.11.3",
		"@codemirror/search": "^6.5.11",
		"@codemirror/state": "^6.5.2",
		"@codemirror/view": "^6.38.6",
		"@pierre/diffs": "^1.1.3",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-toast": "^1.2.15",
		"@radix-ui/react-tooltip": "^1.2.8",
		"@tailwindcss/postcss": "^4.2.1",
		"@tanstack/react-query": "^5.90.21",
		"@tauri-apps/api": "^2",
		"@tauri-apps/plugin-dialog": "^2.6.0",
		"@tauri-apps/plugin-fs": "^2.4.5",
		"@tauri-apps/plugin-log": "^2",
		"@tauri-apps/plugin-opener": "^2",
		"@types/diff": "^8.0.0",
		"@uiw/react-codemirror": "^4.25.2",
		"@xterm/addon-fit": "^0.11.0",
		"@xterm/xterm": "^6.0.0",
		"clsx": "^2.1.1",
		"commander": "^14.0.3",
		"diff": "^8.0.3",
		"lucide-react": "^0.577.0",
		"postcss": "^8.5.8",
		"react": "^19.1.0",
		"react-dom": "^19.1.0",
		"react-router-dom": "^7.8.2",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4.2.1",
		"tailwindcss-animate": "^1.0.7"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.0",
		"@vitejs/plugin-react": "^5.0.0",
		"@types/bun": "latest",
		"@types/node": "^24.3.0",
		"@types/react": "^19.1.8",
		"@types/react-dom": "^19.1.6",
		"tsx": "^4.20.5",
		"typescript": "~5.8.3",
		"vite": "^7.1.3"
	}
}
