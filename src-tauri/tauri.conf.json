{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "Silo Dev",
	"version": "0.1.0",
	"identifier": "new.silo.dev",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:3000",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"title": "",
				"width": 1280,
				"height": 900,
				"titleBarStyle": "Overlay",
				"visible": false,
				"backgroundColor": "#0a0a0c",
				"transparent": true,
				"theme": "Dark"
			}
		],
		"security": {
			"csp": "default-src 'self' ipc: http://ipc.localhost; frame-src 'self'; connect-src 'self' ipc: http://ipc.localhost http: https: ws: wss:; img-src 'self' asset: http://asset.localhost data: http: https:; media-src 'self' blob:; worker-src 'self' blob:; style-src 'self' 'unsafe-inline';",
			"assetProtocol": {
				"enable": true,
				"scope": ["**"]
			}
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons-dev/32x32.png",
			"icons-dev/128x128.png",
			"icons-dev/128x128@2x.png",
			"icons-dev/icon.icns",
			"icons-dev/icon.ico"
		]
	}
}
