{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"opener:default",
		"log:default",
		"updater:default",
		"core:window:default",
		"core:window:allow-start-dragging",
		"core:window:allow-show",
		"dialog:default",
		"fs:default",
		{
			"identifier": "fs:scope",
			"allow": [{ "path": "**" }]
		}
	]
}
